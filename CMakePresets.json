{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 20,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "dev-base",
      "hidden": true,
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    },
    {
      "name": "macos-default",
      "displayName": "macOS Default",
      "description": "Use the host default generator on macOS.",
      "inherits": "dev-base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Darwin"
      }
    },
    {
      "name": "windows-msvc2019",
      "displayName": "Windows MSVC 2019",
      "description": "Visual Studio 2019 x64. Use with a Qt msvc2019_64 kit.",
      "inherits": "dev-base",
      "generator": "Visual Studio 16 2019",
      "architecture": "x64",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      }
    },
    {
      "name": "windows-msvc2022",
      "displayName": "Windows MSVC 2022",
      "description": "Visual Studio 2022 x64. Use with a Qt msvc2022_64 kit.",
      "inherits": "dev-base",
      "generator": "Visual Studio 17 2022",
      "architecture": "x64",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "macos-default",
      "configurePreset": "macos-default"
    },
    {
      "name": "windows-msvc2019-debug",
      "configurePreset": "windows-msvc2019",
      "configuration": "Debug"
    },
    {
      "name": "windows-msvc2019-release",
      "configurePreset": "windows-msvc2019",
      "configuration": "Release"
    },
    {
      "name": "windows-msvc2022-debug",
      "configurePreset": "windows-msvc2022",
      "configuration": "Debug"
    },
    {
      "name": "windows-msvc2022-release",
      "configurePreset": "windows-msvc2022",
      "configuration": "Release"
    }
  ]
}
